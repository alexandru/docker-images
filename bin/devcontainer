#!/usr/bin/env bash
set -euo pipefail

DEFAULT_IMAGE="ghcr.io/alexandru/jdk-build-tools-devcontainer:latest"
IMAGE="${DEVCONTAINER_IMAGE:-$DEFAULT_IMAGE}"
HOME_VOLUME_PREFIX="${DEVCONTAINER_HOME_VOLUME_PREFIX:-${DEVCONTAINER_HOME_VOLUME:-jdk-build-tools-devcontainer-home}-}"
CONTAINER_PREFIX="jdk-build-tools-dev-"
CONTAINER_LABEL="com.alexandru.docker-images.devcontainer=true"
OPENCODE_CONFIG_CONTAINER_DIR="/opt/opencode-config"

usage() {
    local command="${1:-}"

    case "$command" in
        start)
            printf 'Usage: %s start <project-directory>\n' "$0" >&2
            printf '\nStart the devcontainer for a project.\n' >&2
            ;;
        stop)
            printf 'Usage: %s stop <project-directory>\n' "$0" >&2
            printf '\nStop the devcontainer for a project.\n' >&2
            ;;
        restart)
            printf 'Usage: %s restart <project-directory>\n' "$0" >&2
            printf '\nStop and start the devcontainer for a project.\n' >&2
            ;;
        shell)
            printf 'Usage: %s shell <project-directory>\n' "$0" >&2
            printf '\nOpen an interactive shell in the project devcontainer, starting it first if needed.\n' >&2
            ;;
        exec)
            printf 'Usage: %s exec <project-directory> <command> [argument ...]\n' "$0" >&2
            printf '\nRun a command in the project devcontainer, starting it first if needed.\n' >&2
            ;;
        compose)
            printf 'Usage: %s compose <project-directory>\n' "$0" >&2
            printf '\nPrint a docker-compose.yaml for the project devcontainer to stdout.\n' >&2
            ;;
        agent)
            printf 'Usage: %s agent <project-directory> [opencode-argument ...]\n' "$0" >&2
            printf '\nStart opencode in the project devcontainer, starting the container first if needed.\n' >&2
            ;;
        agent-serve)
            printf 'Usage: %s agent-serve <project-directory>\n' "$0" >&2
            printf '\nStart the opencode server in the project devcontainer, starting the container first if needed.\n' >&2
            ;;
        purge)
            printf 'Usage: %s purge <project-directory>\n' "$0" >&2
            printf '\nDelete the project devcontainer and its /home/dev volume.\n' >&2
            ;;
        purge-all)
            printf 'Usage: %s purge-all\n' "$0" >&2
            printf '\nDelete all devcontainer containers and /home/dev volumes. The image is not deleted.\n' >&2
            ;;
        ""|help)
            printf 'Usage:\n' >&2
            printf '  %s start <project-directory>\n' "$0" >&2
            printf '  %s stop <project-directory>\n' "$0" >&2
            printf '  %s restart <project-directory>\n' "$0" >&2
            printf '  %s shell <project-directory>\n' "$0" >&2
            printf '  %s exec <project-directory> <command> [argument ...]\n' "$0" >&2
            printf '  %s compose <project-directory>\n' "$0" >&2
            printf '  %s agent <project-directory> [opencode-argument ...]\n' "$0" >&2
            printf '  %s agent-serve <project-directory>\n' "$0" >&2
            printf '  %s purge <project-directory>\n' "$0" >&2
            printf '  %s purge-all\n' "$0" >&2
            printf '  %s help [command]\n' "$0" >&2
            printf '\nCommands:\n' >&2
            printf '  start        Start the project devcontainer.\n' >&2
            printf '  stop         Stop the project devcontainer.\n' >&2
            printf '  restart      Stop and start the project devcontainer.\n' >&2
            printf '  shell        Open a shell in the project devcontainer.\n' >&2
            printf '  exec         Run a command in the project devcontainer.\n' >&2
            printf '  compose      Print a docker-compose.yaml for the project devcontainer.\n' >&2
            printf '  agent        Start opencode in the project devcontainer.\n' >&2
            printf '  agent-serve  Start the opencode server in the project devcontainer.\n' >&2
            printf '  purge        Delete the project devcontainer and volume.\n' >&2
            printf '  purge-all    Delete all devcontainer containers and volumes.\n' >&2
            printf '  help         Show this help or help for a command.\n' >&2
            ;;
        *)
            printf 'Unknown command: %s\n\n' "$command" >&2
            usage
            return 0
            ;;
    esac

    printf '\nEnvironment:\n' >&2
    printf '  CONTAINER_CLI                     Container CLI to use. Defaults to first available wslc.exe, wslc, docker, or podman.\n' >&2
    printf '  DEVCONTAINER_IMAGE                Image to run. Defaults to %s.\n' "$IMAGE" >&2
    printf '  DEVCONTAINER_HOME_VOLUME_PREFIX   Prefix for per-workspace /home/dev volumes. Defaults to %s.\n' "$HOME_VOLUME_PREFIX" >&2
    printf '  DEVCONTAINER_OPENCODE_GO_API_KEY  Optional OpenCode Go API key forwarded into the container.\n' >&2
    printf '  DEVCONTAINER_OPENCODE_CONFIG_DIR  Optional host config directory mounted read-only; sets OPENCODE_CONFIG_DIR=%s inside the container.\n' "$OPENCODE_CONFIG_CONTAINER_DIR" >&2
}

find_container_cli() {
    if [ -n "${CONTAINER_CLI:-}" ]; then
        printf '%s\n' "$CONTAINER_CLI"
        return 0
    fi

    for cli in wslc.exe wslc docker podman; do
        if command -v "$cli" >/dev/null 2>&1; then
            command -v "$cli"
            return 0
        fi
    done

    return 1
}

canonical_dir() {
    local path="$1"
    local description="$2"

    if [ ! -d "$path" ]; then
        printf '%s directory does not exist: %s\n' "$description" "$path" >&2
        exit 1
    fi

    cd "$path" && pwd -P
}

project_path() {
    canonical_dir "$1" "Project"
}

opencode_config_path() {
    canonical_dir "$1" "OpenCode config"
}

project_token() {
    local project_dir="$1"
    local base slug checksum

    base="$(basename "$project_dir")"
    slug="$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]' | tr -c '[:alnum:]_.-' '-')"
    checksum="$(printf '%s' "$project_dir" | cksum)"
    checksum="${checksum%% *}"

    if [ -z "$slug" ]; then
        slug="project"
    fi

    printf '%s-%s\n' "$slug" "$checksum"
}

container_name() {
    local project_dir="$1"

    printf '%s%s\n' "$CONTAINER_PREFIX" "$(project_token "$project_dir")"
}

home_volume() {
    local project_dir="$1"

    printf '%s%s\n' "$HOME_VOLUME_PREFIX" "$(project_token "$project_dir")"
}

yaml_quote() {
    local value="$1"

    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    printf '"%s"' "$value"
}

has_ssh_auth_sock() {
    [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]
}

container_exists() {
    "$CONTAINER_CLI" inspect "$CONTAINER_NAME" >/dev/null 2>&1
}

configure_opencode_config_mount() {
    if [ -n "${DEVCONTAINER_OPENCODE_CONFIG_DIR:-}" ]; then
        OPENCODE_CONFIG_HOST_DIR="$(opencode_config_path "$DEVCONTAINER_OPENCODE_CONFIG_DIR")"
    fi
}

configure_container_env_args() {
    CONTAINER_ENV_ARGS=()

    if [ -n "${DEVCONTAINER_OPENCODE_GO_API_KEY:-}" ]; then
        CONTAINER_ENV_ARGS+=(-e "OPENCODE_API_KEY=$DEVCONTAINER_OPENCODE_GO_API_KEY")
    fi

    if [ -n "$OPENCODE_CONFIG_HOST_DIR" ]; then
        CONTAINER_ENV_ARGS+=(-e "OPENCODE_CONFIG_DIR=$OPENCODE_CONFIG_CONTAINER_DIR")
    fi
}

container_opencode_config_source() {
    "$CONTAINER_CLI" inspect \
        --format "{{range .Mounts}}{{if eq .Destination \"$OPENCODE_CONFIG_CONTAINER_DIR\"}}{{println .Source}}{{end}}{{end}}" \
        "$CONTAINER_NAME" 2>/dev/null || true
}

ensure_opencode_config_mount() {
    local source

    if [ -z "$OPENCODE_CONFIG_HOST_DIR" ]; then
        return 0
    fi

    source="$(container_opencode_config_source)"
    if [ "$source" != "$OPENCODE_CONFIG_HOST_DIR" ]; then
        printf 'Container already exists without the requested OpenCode config mount.\n' >&2
        printf 'Run `%s purge %q` and start it again to apply DEVCONTAINER_OPENCODE_CONFIG_DIR.\n' "$0" "$PROJECT_DIR" >&2
        exit 1
    fi
}

start_container() {
    if container_exists; then
        ensure_opencode_config_mount
        "$CONTAINER_CLI" start "$CONTAINER_NAME" >/dev/null 2>&1 || true
    else
        "$CONTAINER_CLI" volume create \
            --label "$CONTAINER_LABEL" \
            --label "com.alexandru.docker-images.devcontainer.project=$PROJECT_DIR" \
            "$HOME_VOLUME" >/dev/null 2>&1 || true

        local ssh_args=()
        if has_ssh_auth_sock; then
            ssh_args=(-v "$SSH_AUTH_SOCK:$SSH_AUTH_SOCK" -e "SSH_AUTH_SOCK=$SSH_AUTH_SOCK")
        fi

        local opencode_config_args=()
        if [ -n "$OPENCODE_CONFIG_HOST_DIR" ]; then
            opencode_config_args=(
                -v "$OPENCODE_CONFIG_HOST_DIR:$OPENCODE_CONFIG_CONTAINER_DIR:ro"
            )
        fi

        "$CONTAINER_CLI" run -d \
            --name "$CONTAINER_NAME" \
            --label "$CONTAINER_LABEL" \
            --label "com.alexandru.docker-images.devcontainer.project=$PROJECT_DIR" \
            --label "com.alexandru.docker-images.devcontainer.home-volume=$HOME_VOLUME" \
            -v "$PROJECT_DIR:/workspace" \
            -v "$HOME_VOLUME:/home/dev" \
            "${ssh_args[@]}" \
            "${CONTAINER_ENV_ARGS[@]}" \
            "${opencode_config_args[@]}" \
            -p 10012:10012 \
            -w /workspace \
            "$IMAGE" \
            sleep infinity >/dev/null
    fi

    printf 'Container: %s\n' "$CONTAINER_NAME"
    printf 'Project:   %s -> /workspace\n' "$PROJECT_DIR"
    printf 'Home:      %s -> /home/dev\n' "$HOME_VOLUME"
    printf 'Shell:     %q exec -it %q bash\n' "$CONTAINER_CLI" "$CONTAINER_NAME"
}

exec_container() {
    "$CONTAINER_CLI" exec -it "${CONTAINER_ENV_ARGS[@]}" "$CONTAINER_NAME" /usr/local/bin/devcontainer-entrypoint "$@"
}

stop_container() {
    if container_exists; then
        "$CONTAINER_CLI" stop "$CONTAINER_NAME" >/dev/null 2>&1 || true
        printf 'Stopped: %s\n' "$CONTAINER_NAME"
    else
        printf 'Container does not exist: %s\n' "$CONTAINER_NAME"
    fi
}

shell_container() {
    run_in_container bash
}

exec_command() {
    run_in_container "${COMMAND_ARGS[@]}"
}

agent() {
    run_in_container opencode "${COMMAND_ARGS[@]}"
}

agent_serve() {
    run_in_container opencode serve --port 10012 --hostname "0.0.0.0"
}

run_in_container() {
    start_container >/dev/null
    exec_container "$@"
}

compose_file() {
    compose_service
    compose_home_volume
}

compose_service() {
    printf 'services:\n'
    printf '  devcontainer:\n'
    printf '    image: "${DEVCONTAINER_IMAGE:-%s}"\n' "$DEFAULT_IMAGE"
    printf '    container_name: %s\n' "$(yaml_quote "$CONTAINER_NAME")"
    printf '    working_dir: /workspace\n'
    printf '    command:\n'
    printf '      - sleep\n'
    printf '      - infinity\n'
    printf '    ports:\n'
    printf '      - "10012:10012"\n'
    printf '    labels:\n'
    printf '      com.alexandru.docker-images.devcontainer: "true"\n'
    printf '      com.alexandru.docker-images.devcontainer.project: %s\n' "$(yaml_quote "$PROJECT_DIR")"
    printf '      com.alexandru.docker-images.devcontainer.home-volume: %s\n' "$(yaml_quote "$HOME_VOLUME")"

    compose_environment
    compose_mounts
}

compose_environment() {
    if ! compose_has_environment; then
        return 0
    fi

    printf '    environment:\n'

    if [ -n "${DEVCONTAINER_OPENCODE_GO_API_KEY:-}" ]; then
        printf '      OPENCODE_API_KEY: "${DEVCONTAINER_OPENCODE_GO_API_KEY}"\n'
    fi

    if [ -n "$OPENCODE_CONFIG_HOST_DIR" ]; then
        printf '      OPENCODE_CONFIG_DIR: %s\n' "$(yaml_quote "$OPENCODE_CONFIG_CONTAINER_DIR")"
    fi

    if has_ssh_auth_sock; then
        printf '      SSH_AUTH_SOCK: "${SSH_AUTH_SOCK}"\n'
    fi
}

compose_has_environment() {
    [ -n "${DEVCONTAINER_OPENCODE_GO_API_KEY:-}" ] || [ -n "$OPENCODE_CONFIG_HOST_DIR" ] || has_ssh_auth_sock
}

compose_mounts() {
    printf '    volumes:\n'
    printf '      - type: bind\n'
    printf '        source: %s\n' "$(yaml_quote "$PROJECT_DIR")"
    printf '        target: /workspace\n'
    printf '      - type: volume\n'
    printf '        source: home\n'
    printf '        target: /home/dev\n'

    if [ -n "$OPENCODE_CONFIG_HOST_DIR" ]; then
        printf '      - type: bind\n'
        printf '        source: "${DEVCONTAINER_OPENCODE_CONFIG_DIR}"\n'
        printf '        target: %s\n' "$(yaml_quote "$OPENCODE_CONFIG_CONTAINER_DIR")"
        printf '        read_only: true\n'
    fi

    if has_ssh_auth_sock; then
        printf '      - type: bind\n'
        printf '        source: "${SSH_AUTH_SOCK}"\n'
        printf '        target: "${SSH_AUTH_SOCK}"\n'
    fi
}

compose_home_volume() {
    printf '\nvolumes:\n'
    printf '  home:\n'
    printf '    name: %s\n' "$(yaml_quote "$HOME_VOLUME")"
    printf '    labels:\n'
    printf '      com.alexandru.docker-images.devcontainer: "true"\n'
    printf '      com.alexandru.docker-images.devcontainer.project: %s\n' "$(yaml_quote "$PROJECT_DIR")"
}

purge_container() {
    if container_exists; then
        "$CONTAINER_CLI" rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
        printf 'Deleted container: %s\n' "$CONTAINER_NAME"
    else
        printf 'Container does not exist: %s\n' "$CONTAINER_NAME"
    fi

    purge_volume "$HOME_VOLUME"
}

add_container_ids() {
    local id

    while IFS= read -r id; do
        if [ -n "$id" ]; then
            case " ${CONTAINER_IDS[*]} " in
                *" $id "*) ;;
                *) CONTAINER_IDS+=("$id") ;;
            esac
        fi
    done < <("$CONTAINER_CLI" ps -aq --filter "$1" 2>/dev/null || true)
}

add_volume_name() {
    local volume_name="$1"

    if [ -z "$volume_name" ]; then
        return 0
    fi

    case " ${VOLUME_NAMES[*]} " in
        *" $volume_name "*) ;;
        *) VOLUME_NAMES+=("$volume_name") ;;
    esac
}

add_volume_names() {
    local volume_name

    while IFS= read -r volume_name; do
        add_volume_name "$volume_name"
    done < <("$CONTAINER_CLI" volume ls -q --filter "$1" 2>/dev/null || true)
}

add_container_home_volumes() {
    local container_id="$1"
    local volume_name

    while IFS= read -r volume_name; do
        add_volume_name "$volume_name"
    done < <("$CONTAINER_CLI" inspect --format '{{range .Mounts}}{{if eq .Destination "/home/dev"}}{{println .Name}}{{end}}{{end}}' "$container_id" 2>/dev/null || true)
}

purge_volume() {
    local volume_name="$1"

    if "$CONTAINER_CLI" volume inspect "$volume_name" >/dev/null 2>&1; then
        if "$CONTAINER_CLI" volume rm -f "$volume_name" >/dev/null 2>&1; then
            printf 'Deleted volume: %s\n' "$volume_name"
        else
            printf 'Failed to delete volume: %s\n' "$volume_name" >&2
        fi
    else
        printf 'Volume does not exist: %s\n' "$volume_name"
    fi
}

purge_volumes() {
    local volume_name

    if [ "${#VOLUME_NAMES[@]}" -eq 0 ]; then
        printf 'No devcontainer volumes found.\n'
        return 0
    fi

    for volume_name in "${VOLUME_NAMES[@]}"; do
        purge_volume "$volume_name"
    done
}

purge_all() {
    local CONTAINER_IDS=()
    local VOLUME_NAMES=()
    local container_id

    add_container_ids "ancestor=$IMAGE"
    add_container_ids "label=$CONTAINER_LABEL"

    for container_id in "${CONTAINER_IDS[@]}"; do
        add_container_home_volumes "$container_id"
    done

    add_volume_names "label=$CONTAINER_LABEL"
    add_volume_names "name=$HOME_VOLUME_PREFIX"

    if [ "${#CONTAINER_IDS[@]}" -gt 0 ]; then
        "$CONTAINER_CLI" rm -f "${CONTAINER_IDS[@]}" >/dev/null 2>&1 || true
        printf 'Deleted devcontainer containers: %s\n' "${#CONTAINER_IDS[@]}"
    else
        printf 'No devcontainer containers found.\n'
    fi

    purge_volumes
}

if [ "$#" -lt 1 ]; then
    usage
    exit 1
fi

case "$1" in
    -h|--help)
        usage
        exit 0
        ;;
    help)
        if [ "$#" -gt 2 ]; then
            usage help
            exit 1
        fi

        usage "${2:-help}"
        exit 0
        ;;
esac

if [ "$#" -ge 2 ] && { [ "$2" = "-h" ] || [ "$2" = "--help" ]; }; then
    usage "$1"
    exit 0
fi

COMMAND="$1"
PROJECT_DIR=""
OPENCODE_CONFIG_HOST_DIR=""
COMMAND_ARGS=()
CONTAINER_ENV_ARGS=()

case "$COMMAND" in
    start|stop|restart|shell|compose|agent-serve|purge)
        if [ "$#" -ne 2 ]; then
            usage "$COMMAND"
            exit 1
        fi

        PROJECT_DIR="$(project_path "$2")"
        ;;
    agent)
        if [ "$#" -lt 2 ]; then
            usage "$COMMAND"
            exit 1
        fi

        PROJECT_DIR="$(project_path "$2")"
        COMMAND_ARGS=("${@:3}")
        ;;
    exec)
        if [ "$#" -lt 3 ]; then
            usage "$COMMAND"
            exit 1
        fi

        PROJECT_DIR="$(project_path "$2")"
        COMMAND_ARGS=("${@:3}")
        ;;
    purge-all)
        if [ "$#" -ne 1 ]; then
            usage "$COMMAND"
            exit 1
        fi
        ;;
    *)
        usage
        exit 1
        ;;
esac

if [ -n "$PROJECT_DIR" ]; then
    CONTAINER_NAME="$(container_name "$PROJECT_DIR")"
    HOME_VOLUME="$(home_volume "$PROJECT_DIR")"
fi

case "$COMMAND" in
    start|restart|shell|exec|compose|agent|agent-serve)
        configure_opencode_config_mount
        ;;
esac

configure_container_env_args

if [ "$COMMAND" != "compose" ]; then
    CONTAINER_CLI="$(find_container_cli)" || {
        printf 'No container CLI found. Install wslc.exe, docker, or podman, or set CONTAINER_CLI.\n' >&2
        exit 1
    }
fi

case "$COMMAND" in
    start)
        start_container
        ;;
    stop)
        stop_container
        ;;
    restart)
        stop_container
        start_container
        ;;
    shell)
        shell_container
        ;;
    exec)
        exec_command
        ;;
    compose)
        compose_file
        ;;
    agent)
        agent
        ;;
    agent-serve)
        agent_serve
        ;;
    purge)
        purge_container
        ;;
    purge-all)
        purge_all
        ;;
    *)
        usage
        exit 1
        ;;
esac
